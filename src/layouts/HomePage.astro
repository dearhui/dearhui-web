---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title}>
    <div class="page">
        <main class="container">
            <p class="greeting">{frontmatter.greeting}</p>
            <h1 class="name">{frontmatter.name}</h1>
            <p class="role">{frontmatter.role}</p>

            <div class="content">
                <slot />
            </div>

            <nav class="links">
                {frontmatter.links.map((link: { label: string; url: string }) => (
                    <a href={link.url} target={link.url.startsWith('/') ? undefined : '_blank'}>{link.label}</a>
                ))}
            </nav>
        </main>
    </div>
</BaseLayout>

<style>
    .page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        background: #fafafa;
    }

    .container {
        max-width: 560px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .greeting {
        font-size: 0.95rem;
        color: #94a3b8;
        margin-bottom: 0.25rem;
    }

    .name {
        font-size: 2.5rem;
        font-weight: 800;
        color: #111;
        letter-spacing: -0.02em;
        margin-bottom: 0.25rem;
    }

    .role {
        font-size: 1.1rem;
        color: #64748b;
        margin-bottom: 2rem;
    }

    .content {
        font-size: 1rem;
        color: #475569;
        line-height: 1.8;
        margin-bottom: 2rem;
    }

    .content :global(p) {
        margin-bottom: 1rem;
    }

    .content :global(h2) {
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #94a3b8;
        margin: 2rem 0 1rem;
    }

    .content :global(a) {
        display: block;
        padding: 1.25rem 1.5rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        text-decoration: none;
        color: #111;
        font-weight: 500;
        transition: border-color 0.2s, box-shadow 0.2s;
        margin-bottom: 0.75rem;
    }

    .content :global(a:hover) {
        border-color: #c7c7c7;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .links {
        display: flex;
        gap: 1.5rem;
    }

    .links a {
        color: #111;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        padding-bottom: 2px;
        border-bottom: 1.5px solid #d1d5db;
        transition: border-color 0.2s;
    }

    .links a:hover {
        border-color: #111;
    }

    @media (max-width: 640px) {
        .container { padding: 3rem 1.5rem; }
        .name { font-size: 2rem; }
    }
</style>
