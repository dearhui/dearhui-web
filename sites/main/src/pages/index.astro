---
import BaseLayout from "../layouts/BaseLayout.astro";

const apps = [
    {
        name: "台股ETF",
        nameEn: "TW ETF",
        description: "主動式 ETF 換股雷達，每個交易日自動比對持股異動；折溢價總覽、配息日曆、庫存管理。",
        url: "https://twetf.dearhui.com",
        screenshot: "/screenshots/twetf.jpg",
        color: "text-teal-600",
        bg: "bg-teal-50",
        btnBg: "bg-teal-600 hover:bg-teal-700",
        badge: "即將上架",
    },
    {
        name: "看診進度助手",
        nameEn: "Clinic Progress",
        description: "門診看診進度即時查詢，搭配鎖定畫面小工具，隨時掌握叫號。",
        url: "https://clinic.dearhui.com",
        screenshot: "/screenshots/clinic.png",
        color: "text-orange-500",
        bg: "bg-orange-50",
        btnBg: "bg-orange-500 hover:bg-orange-600",
    },
    {
        name: "基金看板",
        nameEn: "MyFunds",
        description: "智慧理財助手，輕鬆追蹤與分析基金投資，打造個人化投資組合。",
        url: "https://myfunds.dearhui.com",
        screenshot: "/screenshots/myfunds.png",
        color: "text-amber-500",
        bg: "bg-amber-50",
        btnBg: "bg-amber-500 hover:bg-amber-600",
    },
    {
        name: "台灣垃圾通",
        nameEn: "Taiwan Trash Truck",
        description: "即時垃圾車追蹤，在地圖上查看垃圾車位置，不再錯過垃圾車。",
        url: "https://trashtruck.dearhui.com",
        screenshot: "/screenshots/trashtruck.jpg",
        color: "text-emerald-500",
        bg: "bg-emerald-50",
        btnBg: "bg-emerald-500 hover:bg-emerald-600",
    },
];

const skills = [
    { name: "Swift", icon: "🔶" },
    { name: "SwiftUI", icon: "📱" },
    { name: "UIKit", icon: "🖼" },
    { name: "Xcode", icon: "🛠" },
    { name: "Core Data", icon: "💾" },
    { name: "WidgetKit", icon: "📌" },
    { name: "StoreKit", icon: "💰" },
    { name: "Astro", icon: "🚀" },
];
---

<BaseLayout title="dearhui — iOS Developer & App Creator" description="熱愛創造有意義的 iOS 應用程式，專注於提升使用者體驗與解決日常生活問題。">
    <!-- Hero -->
    <section class="overflow-hidden px-6 pb-20 pt-16 sm:pb-28 sm:pt-24">
        <div class="mx-auto max-w-5xl">
            <div class="text-center">
                <h1 class="text-gradient text-5xl font-bold tracking-tight sm:text-6xl lg:text-7xl">
                    dearhui
                </h1>
                <p class="mt-3 text-xl text-gray-500">
                    iOS Developer & App Creator
                </p>
                <p class="mx-auto mt-5 max-w-lg text-base leading-relaxed text-gray-500">
                    熱愛創造有意義的 iOS 應用程式，專注於提升使用者體驗與解決日常生活問題。
                </p>
                <div class="mt-8 flex flex-wrap justify-center gap-3">
                    <a
                        href="mailto:dearhui.studio@gmail.com"
                        class="inline-flex items-center gap-2 rounded-full bg-gray-900 px-5 py-2.5 text-sm font-medium text-white no-underline transition hover:-translate-y-0.5 hover:shadow-lg"
                    >
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                        </svg>
                        聯繫我
                    </a>
                    <a
                        href="https://apps.apple.com/tw/developer/dearhui-studio/id452688810"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 rounded-full border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 no-underline transition hover:-translate-y-0.5 hover:shadow-lg"
                    >
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                        </svg>
                        App Store
                    </a>
                </div>
            </div>

            <!-- Hero Mockups -->
            <div class="mt-16 flex items-end justify-center gap-4 sm:gap-6 lg:gap-8">
                <div class="iphone-mockup-sm hidden -rotate-6 sm:block">
                    <img src="/screenshots/clinic.png" alt="看診進度助手" />
                </div>
                <div class="iphone-mockup-md">
                    <img src="/screenshots/twetf.jpg" alt="台股ETF" />
                </div>
                <div class="iphone-mockup-sm hidden rotate-6 sm:block">
                    <img src="/screenshots/trashtruck.jpg" alt="台灣垃圾通" />
                </div>
            </div>
        </div>
    </section>

    <!-- Apps -->
    <section class="bg-gray-50 px-6 py-20 sm:py-28">
        <div class="mx-auto max-w-5xl">
            <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">我的作品</h2>
            <p class="mx-auto mt-3 max-w-lg text-center text-gray-500">
                為台灣使用者打造的實用工具
            </p>

            <div class="mt-14 space-y-8">
                {apps.map((app, i) => (
                    <a
                        href={app.url}
                        class="animate-on-scroll group flex flex-col items-center gap-8 rounded-3xl border border-gray-200 bg-white p-8 no-underline transition hover:-translate-y-1 hover:shadow-xl sm:p-10 lg:flex-row lg:gap-12"
                    >
                        {/* Screenshot */}
                        <div class={`flex flex-shrink-0 justify-center ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
                            <div class="iphone-mockup-card">
                                <img src={app.screenshot} alt={app.name} />
                            </div>
                        </div>
                        {/* Text */}
                        <div class={`flex-1 text-center lg:text-left ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
                            <span class={`text-sm font-medium ${app.color}`}>{app.nameEn}</span>
                            <h3 class="mt-1 text-2xl font-bold text-gray-900 sm:text-3xl">
                                {app.name}
                                {app.badge && (
                                    <span class={`ml-2 inline-block translate-y-[-2px] rounded-full ${app.bg} px-3 py-1 align-middle text-xs font-medium ${app.color}`}>
                                        {app.badge}
                                    </span>
                                )}
                            </h3>
                            <p class="mt-3 text-base leading-relaxed text-gray-500">
                                {app.description}
                            </p>
                            <div class="mt-5">
                                <span class={`inline-flex items-center gap-1 rounded-full ${app.btnBg} px-5 py-2.5 text-sm font-medium text-white transition group-hover:shadow-md`}>
                                    前往網站
                                    <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                                    </svg>
                                </span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <!-- About -->
    <section class="px-6 py-20 sm:py-28">
        <div class="mx-auto max-w-5xl">
            <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">關於我</h2>
            <p class="mx-auto mt-4 max-w-2xl text-center text-lg leading-relaxed text-gray-500">
                獨立 iOS 開發者，專注於打造簡潔實用的原生 App。相信好的軟體應該解決真實的問題，帶來直覺流暢的使用體驗。
            </p>

            <div class="mt-14 flex flex-wrap justify-center gap-3">
                {skills.map((skill) => (
                    <span class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700">
                        <span>{skill.icon}</span>
                        {skill.name}
                    </span>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>
