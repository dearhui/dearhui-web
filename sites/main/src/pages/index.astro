---
import BaseLayout from "../layouts/BaseLayout.astro";

const apps = [
    {
        name: "看診進度助手",
        nameEn: "Clinic Progress",
        description: "台大醫院門診看診進度即時查詢",
        url: "https://clinic.dearhui.com",
        accent: "border-l-indigo-500",
        bg: "bg-indigo-50 dark:bg-indigo-950/20",
        hoverBorder: "hover:border-indigo-300 dark:hover:border-indigo-700",
        linkColor: "text-indigo-600 dark:text-indigo-400",
    },
    {
        name: "台灣垃圾通",
        nameEn: "Taiwan Trash Truck",
        description: "即時垃圾車追蹤，不再錯過垃圾車",
        url: "https://trashtruck.dearhui.com",
        accent: "border-l-emerald-500",
        bg: "bg-emerald-50 dark:bg-emerald-950/20",
        hoverBorder: "hover:border-emerald-300 dark:hover:border-emerald-700",
        linkColor: "text-emerald-600 dark:text-emerald-400",
    },
    {
        name: "基金看板",
        nameEn: "MyFunds",
        description: "讓理財變得輕鬆易懂",
        url: "https://myfunds.dearhui.com",
        accent: "border-l-amber-500",
        bg: "bg-amber-50 dark:bg-amber-950/20",
        hoverBorder: "hover:border-amber-300 dark:hover:border-amber-700",
        linkColor: "text-amber-600 dark:text-amber-400",
    },
];
---

<BaseLayout title="dearhui — iOS Developer & App Creator" description="熱愛創造有意義的 iOS 應用程式，專注於提升使用者體驗與解決日常生活問題。">
    <!-- Hero -->
    <section class="mx-auto max-w-4xl px-6 py-16 sm:py-24">
        <h1 class="text-gradient text-4xl font-bold tracking-tight sm:text-5xl">
            dearhui
        </h1>
        <p class="mt-2 text-lg text-gray-500 dark:text-gray-400">
            iOS Developer & App Creator
        </p>
        <p class="mt-4 max-w-lg text-base leading-relaxed text-gray-700 dark:text-gray-300">
            熱愛創造有意義的 iOS 應用程式，專注於提升使用者體驗與解決日常生活問題。
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
            <a
                href="mailto:dearhui.studio@gmail.com"
                class="inline-flex items-center gap-2 rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 no-underline transition hover:border-gray-400 hover:shadow-sm dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300 dark:hover:border-gray-600"
            >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                Email
            </a>
            <a
                href="https://apps.apple.com/tw/developer/ming-hui-chung/id600411410"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 no-underline transition hover:border-gray-400 hover:shadow-sm dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300 dark:hover:border-gray-600"
            >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                </svg>
                App Store
            </a>
        </div>
    </section>

    <!-- Apps -->
    <section class="mx-auto max-w-4xl px-6 pb-20">
        <h2 class="mb-8 text-2xl font-bold">Apps</h2>
        <div class="grid gap-4 sm:grid-cols-3">
            {apps.map((app) => (
                <a
                    href={app.url}
                    class={`block rounded-xl border border-l-4 ${app.accent} ${app.bg} border-gray-200 p-6 no-underline transition hover:-translate-y-1 hover:shadow-lg ${app.hoverBorder} dark:border-gray-800`}
                >
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                        {app.name}
                    </h3>
                    <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">
                        {app.nameEn}
                    </p>
                    <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
                        {app.description}
                    </p>
                    <p class={`mt-3 text-sm font-medium ${app.linkColor}`}>
                        前往網站 &rarr;
                    </p>
                </a>
            ))}
        </div>
    </section>
</BaseLayout>
